{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.14.2/.schema/devbox.schema.json",
  "packages": [
    "argocd@latest",
    "nushell@0.104.0",
    "k9s@latest",
    "postgresql@latest",
    "barman@latest",
    "teller@1.5.6",
    "kafkactl@latest",
    "kcat@latest",
    "kyverno-chainsaw@0.1.9",
    "just@latest",
    "python@latest",
    "uv@latest"
  ],
  "shell": {
    "init_hook": [
      "chmod +x ops",
      "export PATH=$PATH:$PWD",
      "[ -s \"$HOME/.nvm/nvm.sh\" ] && . \"$HOME/.nvm/nvm.sh\"",
      "[ -d \"$VENV_DIR\" ] && . $VENV_DIR/bin/activate"
    ],
    "scripts": {
      "argocd-login": ["./ops argocd login"],
      "freshrss-psql": ["./ops freshrss psql"],
      "freshrss-publish-links": ["./ops freshrss publish-links"],
      "freshrss-update-news": ["./ops freshrss update-news"],
      "freshrss-update-technical": ["./ops freshrss update-technical"],
      "freshrss-update-feed": ["./ops freshrss update-feed"],
      "node-uptime": ["./ops cluster node-uptime"],
      "node-status": ["./ops cluster node-status"],
      "test": [
        "echo \"Error: no test specified\" && exit 1"
      ]
    }
  }
}
